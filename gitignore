# HH-LEWS — .gitignore

# ─────────────────────────────────────────
# SECRETS & ENV — NEVER COMMIT THESE
# ─────────────────────────────────────────
.env
.env.local
.env.development
.env.production
*.pem
private.pem
public.pem

# ─────────────────────────────────────────
