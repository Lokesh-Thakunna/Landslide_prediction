# HH-LEWS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file. It is already in .gitignore.

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
# Postgres connection string — auto-set by docker-compose for local dev
DATABASE_URL=postgresql://hhlews:hhlews_password@localhost:5432/hhlews_db

# ─────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────
# Redis connection — auto-set by docker-compose for local dev
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────
# JWT (RS256 Asymmetric)
# ─────────────────────────────────────────
# Generate with:
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the full PEM content (including -----BEGIN/END----- lines)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ─────────────────────────────────────────
# PHONE ENCRYPTION (Fernet AES-256)
# ─────────────────────────────────────────
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CRITICAL: Back this up securely. Lost key = all subscriber phones unrecoverable.
PHONE_ENCRYPTION_KEY=

# ─────────────────────────────────────────
# WEATHER API
# ─────────────────────────────────────────
# Sign up at openweathermap.org — free tier (1,000 calls/day)
OPENWEATHERMAP_API_KEY=

# Open-Meteo requires no API key (open source) — no action needed

# ─────────────────────────────────────────
# TWILIO — SMS + WHATSAPP
# ─────────────────────────────────────────
# Get from console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# WhatsApp Sandbox (from console.twilio.com/console/sms/whatsapp/sandbox)
WHATSAPP_API_TOKEN=
WHATSAPP_FROM=whatsapp:+14155238886

# ─────────────────────────────────────────
# ML INTERNAL SERVICE KEY
# ─────────────────────────────────────────
# Shared secret between Node.js API and FastAPI ML service
# Generate with: openssl rand -hex 32
ML_INTERNAL_API_KEY=

# ─────────────────────────────────────────
# MQTT BROKER
# ─────────────────────────────────────────
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=hhlews_worker
MQTT_PASSWORD=

# ─────────────────────────────────────────
# NODE.JS API CONFIG
# ─────────────────────────────────────────
NODE_ENV=development
PORT=3000
ML_SERVICE_URL=http://hhlews-ml:8000

# ─────────────────────────────────────────
# FRONTEND (set these in Vercel for production)
# ─────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
